{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "blueprint": {
    "title": "PPT Generation Blueprint for AI Agent",
    "version": "2.0.0",
    "description": "标准化结构化指令文档，指导 AI Agent 自主完成项目解析 → 内容策划 → JSON 构建 → HTML 输出的全流程 PPT 生成",
    "last_updated": "2026-07-14"
  },

  "project_reading_rules": {
    "description": "AI Agent 在解析项目时，需按以下规则读取并理解项目结构",
    "root_path": "${PROJECT_ROOT}",
    "rules": [
      {
        "id": "PRR-01",
        "priority": "mandatory",
        "action": "读取 ${PROJECT_ROOT}/README.md",
        "purpose": "获取项目概述、功能特性、使用方式",
        "fallback": "若不存在则尝试读取 docs/reference/project_reference_template.md"
      },
      {
        "id": "PRR-02",
        "priority": "mandatory",
        "action": "遍历 ${PROJECT_ROOT}/project_content/ 下所有子目录",
        "purpose": "定位目标项目文件夹，识别项目名称和类型"
      },
      {
        "id": "PRR-03",
        "priority": "mandatory",
        "action": "读取目标项目的核心配置文件（settings.py / pyproject.toml / package.json / requirements.txt）",
        "purpose": "获取技术栈、依赖版本、项目元信息"
      },
      {
        "id": "PRR-04",
        "priority": "highly_recommended",
        "action": "读取目标项目的 models.py / schema.prisma / 数据模型定义文件",
        "purpose": "理解核心数据实体与关系，为 PPT 内容提供结构支撑"
      },
      {
        "id": "PRR-05",
        "priority": "recommended",
        "action": "读取目标项目的 urls.py / routes 文件",
        "purpose": "理解系统路由结构与模块划分"
      },
      {
        "id": "PRR-06",
        "priority": "recommended",
        "action": "读取目标项目的 .github/workflows/*.yml 或 Dockerfile",
        "purpose": "获取部署与 CI/CD 流程信息"
      },
      {
        "id": "PRR-07",
        "priority": "optional",
        "action": "读取目标项目的 tests/ 或 test_*.py 文件",
        "purpose": "了解测试覆盖与质量保证策略"
      },
      {
        "id": "PRR-08",
        "priority": "mandatory",
        "action": "汇总所有读取信息，生成项目摘要（summary）对象",
        "purpose": "为后续 PPT 内容策划提供结构化输入"
      }
    ],
    "output_schema": {
      "type": "object",
      "description": "项目摘要的标准格式",
      "required": ["project_name", "project_type", "tech_stack", "architecture", "core_features", "deployment", "value_proposition"],
      "properties": {
        "project_name": { "type": "string", "description": "项目名称" },
        "project_type": { "type": "string", "enum": ["web_app", "cli_tool", "library", "blog", "ecommerce", "api", "other"], "description": "项目类型" },
        "tech_stack": {
          "type": "object",
          "required": ["backend", "frontend", "database", "devops"],
          "properties": {
            "backend": { "type": "array", "items": { "type": "string" } },
            "frontend": { "type": "array", "items": { "type": "string" } },
            "database": { "type": "array", "items": { "type": "string" } },
            "devops": { "type": "array", "items": { "type": "string" } }
          }
        },
        "architecture": { "type": "string", "description": "架构概要描述" },
        "core_features": { "type": "array", "items": { "type": "object", "properties": { "name": { "type": "string" }, "description": { "type": "string" } } } },
        "deployment": { "type": "string", "description": "部署方式" },
        "value_proposition": { "type": "string", "description": "项目核心价值主张" }
      }
    }
  },

  "available_skills": {
    "description": "系统可调用的技能列表，AI Agent 可根据需要选择性激活",
    "skill_discovery_path": "${PROJECT_ROOT}/.trae/skills/",
    "skills": [
      {
        "skill_id": "ppt-generator",
        "name": "PPT 生成器",
        "discovery_path": "${PROJECT_ROOT}/.trae/skills/ppt-generator/SKILL.md",
        "version": "1.0.0",
        "capabilities": ["需求分析", "内容策划", "文本创作", "配图建议", "PPTX 生成"],
        "invocation_schema": {
          "type": "object",
          "description": "调用 ppt-generator 技能时的输入参数",
          "required": ["project_summary", "output_format", "style_name"],
          "properties": {
            "project_summary": {
              "type": "object",
              "description": "由 project_reading_rules 输出的项目摘要对象"
            },
            "output_format": {
              "type": "string",
              "enum": ["pptx", "html"],
              "description": "输出格式：pptx（python-pptx 脚本生成）或 html（直接渲染）"
            },
            "style_name": {
              "type": "string",
              "enum": ["dark-tech", "warm-elegant", "mint-fresh", "cyber-neon", "minimal-clean"],
              "description": "PPT 视觉风格名称"
            },
            "slide_count": {
              "type": "integer",
              "minimum": 5,
              "maximum": 25,
              "default": 12,
              "description": "期望的幻灯片页数"
            },
            "language": {
              "type": "string",
              "enum": ["zh-CN", "en", "ja"],
              "default": "zh-CN",
              "description": "PPT 内容语言"
            }
          }
        },
        "workflow": [
          { "step": 1, "action": "AI 分析项目摘要，确定主题、受众、场景", "requires_script": false },
          { "step": 2, "action": "AI 策划 PPT 结构（封面→章节→内容→结束）", "requires_script": false },
          { "step": 3, "action": "AI 撰写每页文案，遵循 ≤20 字要点规范", "requires_script": false },
          { "step": 4, "action": "AI 整理为结构化 JSON", "requires_script": false },
          { "step": 5, "action": "调用 generate_pptx.py 或直接渲染 HTML", "requires_script": true }
        ]
      },
      {
        "skill_id": "web-design-analyzer",
        "name": "Web Design Analyzer",
        "discovery_path": "${PROJECT_ROOT}/.trae/skills/web-design-analyzer/SKILL.md",
        "version": "1.0.0",
        "capabilities": ["视觉风格识别", "色彩系统提取", "排版分析", "组件特征识别", "JSON 输出"],
        "invocation_schema": {
          "type": "object",
          "description": "调用 web-design-analyzer 技能时的输入参数",
          "required": ["image_path"],
          "properties": {
            "image_path": { "type": "string", "description": "网页截图文件路径" },
            "model": { "type": "string", "default": "gpt-4o", "description": "视觉分析模型" },
            "output_path": { "type": "string", "default": "./output/design_system.json", "description": "分析结果输出路径" }
          }
        },
        "workflow": [
          { "step": 1, "action": "AI 自主分析图片（或回退调用 analyze_design.py）", "requires_script": false },
          { "step": 2, "action": "生成设计系统 JSON 数据", "requires_script": false },
          { "step": 3, "action": "生成前端 Coding Prompt", "requires_script": false }
        ]
      }
    ]
  },

  "ppt_generation_pipeline": {
    "description": "从项目解析到 HTML-PPT 输出的完整执行管线",
    "pipeline_id": "pipeline-ppt-gen-v2",
    "phases": [
      {
        "phase": 1,
        "name": "项目解析",
        "description": "AI Agent 根据 project_reading_rules 解析目标项目",
        "input_source": "${PROJECT_ROOT}/project_content/",
        "output": "project_summary（JSON 对象）",
        "execution": "autonomous",
        "validation": "确保 project_summary 包含所有 required 字段"
      },
      {
        "phase": 2,
        "name": "风格选择",
        "description": "从可用风格中选择或由用户指定",
        "available_styles": ["dark-tech", "warm-elegant", "mint-fresh", "cyber-neon", "minimal-clean"],
        "reference_path": "${PROJECT_ROOT}/docs/styles/",
        "output": "style_config（配色方案 + CSS 变量）",
        "execution": "user_input_or_default",
        "default_style": "warm-elegant"
      },
      {
        "phase": 3,
        "name": "内容策划与创作",
        "description": "AI 自主完成内容结构规划与文案撰写",
        "execution": "autonomous",
        "sub_phases": [
          { "step": "3.1", "action": "确定 PPT 结构大纲（封面→3-5 章节→结束）" },
          { "step": "3.2", "action": "为每页分配布局类型" },
          { "step": "3.3", "action": "撰写每页标题与要点文案" },
          { "step": "3.4", "action": "为每页添加演讲者备注" }
        ],
        "output": "content_plan（页面级内容规划）"
      },
      {
        "phase": 4,
        "name": "HTML 渲染",
        "description": "将内容计划渲染为可交互的 HTML 演示文稿",
        "execution": "autonomous",
        "sub_phases": [
          { "step": "4.1", "action": "生成完整 HTML 文件，嵌入 style_config 的 CSS 变量" },
          { "step": "4.2", "action": "添加键盘导航、触屏滑动、底部导航点等交互" },
          { "step": "4.3", "action": "添加响应式媒体查询" },
          { "step": "4.4", "action": "保存到 ${PROJECT_ROOT}/output/ 目录" }
        ],
        "output": "${PROJECT_ROOT}/output/${PROJECT_NAME}_Presentation.html",
        "html_template_constraints": {
          "zero_external_dependencies": true,
          "responsive_breakpoints": ["max-width: 820px", "max-width: 480px"],
          "navigation": ["keyboard_arrows", "touch_swipe", "dot_nav", "page_counter"],
          "accessibility": ["semantic_headings", "color_contrast_WCAG_AA"]
        }
      },
      {
        "phase": 5,
        "name": "输出验证",
        "description": "验证最终输出文件的完整性与正确性",
        "execution": "autonomous",
        "checks": [
          { "check_id": "V-01", "description": "HTML 文件存在且非空", "critical": true },
          { "check_id": "V-02", "description": "所有 Slide 的 content 字段非空", "critical": true },
          { "check_id": "V-03", "description": "封面标题与项目名称一致", "critical": false },
          { "check_id": "V-04", "description": "导航功能正常（前/后/跳转）", "critical": true },
          { "check_id": "V-05", "description": "响应式布局在 3 种断点下可正常展示", "critical": false }
        ]
      }
    ]
  },

  "error_handling": {
    "description": "AI Agent 在执行过程中可能遇到的异常情况及处理策略",
    "strategies": [
      {
        "error_type": "project_not_found",
        "condition": "project_content/ 目录为空或不存在目标项目",
        "action": "提示用户将项目源码放入 project_content/ 目录，并提供存放规范"
      },
      {
        "error_type": "missing_requirements",
        "condition": "依赖包未安装",
        "action": "自动执行 pip install -r requirements.txt"
      },
      {
        "error_type": "skill_not_found",
        "condition": ".trae/skills/ 下缺少目标 SKILL.md",
        "action": "以通用流程执行（AI 自主完成全流程，跳过脚本调用步骤）"
      },
      {
        "error_type": "encoding_error",
        "condition": "系统编码非 UTF-8（如 cp932）",
        "action": "在脚本开始处添加 sys.stdout 编码兼容处理"
      },
      {
        "error_type": "output_path_missing",
        "condition": "output/ 目录不存在",
        "action": "自动创建 output/ 目录"
      }
    ]
  },

  "output_delivery": {
    "description": "最终交付物的路径与格式规范",
    "deliverables": [
      {
        "type": "html_presentation",
        "path_template": "${PROJECT_ROOT}/output/${PROJECT_NAME}_Presentation.html",
        "format": "single_page_html",
        "required_features": ["keyboard_nav", "touch_support", "dot_navigation", "responsive_design", "smooth_transitions"]
      },
      {
        "type": "presentation_notes",
        "path_template": "${PROJECT_ROOT}/output/${PROJECT_NAME}_Presentation.html",
        "description": "演讲者备注通过 HTML 的注释或 data-notes 属性嵌入"
      }
    ]
  }
}
